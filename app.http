2.565
--WebAppBoundary
Content-Disposition: form-data; name="longitude"

98.690
--WebAppBoundary
Content-Disposition: form-data; name="hargaTiket"

20000
--WebAppBoundary
Content-Disposition: form-data; name="jamBuka"

07:00 - 18:00
--WebAppBoundary
Content-Disposition: form-data; name="kontak"

081234567891
--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="example.png"

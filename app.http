## Environment
@BaseUrl = http://127.0.0.1:8000
# @BaseUrl = https://pam-2026-p7-ifs23021-be.marshalll.fun:8080

## Shared files
@ImageFile = ./example.png

## Root
### Health Check
GET {{BaseUrl}}/
Content-Type: application/json

## Profile
### Get Profile
# @name GetProfile
GET {{BaseUrl}}/profile
Content-Type: application/json

### Get Profile Photo
# @name GetProfilePhoto
GET {{BaseUrl}}/profile/photo
Content-Type: application/json

## Plants
### Get All Plants
# @name GetAllPlants
GET {{BaseUrl}}/plants?search=
Content-Type: application/json

### Create Plant
# @name CreatePlant
POST {{BaseUrl}}/plants
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="nama"

Kangkung
--WebAppBoundary
Content-Disposition: form-data; name="deskripsi"

Sayuran hijau yang kaya vitamin, mineral, dan serat.
--WebAppBoundary
Content-Disposition: form-data; name="manfaat"

Membantu menjaga daya tahan tubuh dan kesehatan mata.
--WebAppBoundary
Content-Disposition: form-data; name="efekSamping"

Dapat menyebabkan kembung jika dikonsumsi berlebihan.
--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="example.png"
Content-Type: image/png

< {{ImageFile}}
--WebAppBoundary--

> {%
    client.global.set("plantId", response.body.data.plantId);
%}

### Get Plant By Id
# @name GetPlantById
GET {{BaseUrl}}/plants/{{plantId}}
Content-Type: application/json

### Get Plant Image
# @name GetPlantImageById
GET {{BaseUrl}}/plants/{{plantId}}/image
Content-Type: application/json

### Update Plant Data Only
# @name UpdatePlantData
PUT {{BaseUrl}}/plants/{{plantId}}
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="nama"

Kangkung Update
--WebAppBoundary
Content-Disposition: form-data; name="deskripsi"

Deskripsi tanaman diperbarui.
--WebAppBoundary
Content-Disposition: form-data; name="manfaat"

Manfaat tanaman diperbarui.
--WebAppBoundary
Content-Disposition: form-data; name="efekSamping"

Efek samping tanaman diperbarui.
--WebAppBoundary--

### Update Plant With Image
# @name UpdatePlant
PUT {{BaseUrl}}/plants/{{plantId}}
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="nama"

Kangkung Final
--WebAppBoundary
Content-Disposition: form-data; name="deskripsi"

Deskripsi final tanaman.
--WebAppBoundary
Content-Disposition: form-data; name="manfaat"

Manfaat final tanaman.
--WebAppBoundary
Content-Disposition: form-data; name="efekSamping"

Efek samping final tanaman.
--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="example.png"
Content-Type: image/png

< {{ImageFile}}
--WebAppBoundary--

### Delete Plant
# @name DeletePlant
DELETE {{BaseUrl}}/plants/{{plantId}}
Content-Type: application/json

## Destinations
### Get All Destinations
# @name GetAllDestinations
GET {{BaseUrl}}/destinations?search=&kategori=
Content-Type: application/json

### Create Destination
# @name CreateDestination
POST {{BaseUrl}}/destinations
Content-Type: multipart/form-data; boundary=WebAppBoundary

--WebAppBoundary
Content-Disposition: form-data; name="nama"

Bukit Holbung
--WebAppBoundary
Content-Disposition: form-data; name="slug"

bukit-holbung
--WebAppBoundary
Content-Disposition: form-data; name="kategori"

Alam
--WebAppBoundary
Content-Disposition: form-data; name="deskripsi"

Destinasi perbukitan dengan panorama Danau Toba.
--WebAppBoundary
Content-Disposition: form-data; name="lokasi"

Samosir
--WebAppBoundary
Content-Disposition: form-data; name="latitude"

2.564
--WebAppBoundary
Content-Disposition: form-data; name="longitude"

98.689
--WebAppBoundary
Content-Disposition: form-data; name="hargaTiket"

15000
--WebAppBoundary
Content-Disposition: form-data; name="jamBuka"

08:00 - 18:00
--WebAppBoundary
Content-Disposition: form-data; name="kontak"

081234567890
--WebAppBoundary
Content-Disposition: form-data; name="file"; filename="example.png"
Content-Type: image/png

< {{ImageFile}}
--WebAppBoundary--

> {%
    client.global.set("destinationId", response.body.data.destinationId);
%}

